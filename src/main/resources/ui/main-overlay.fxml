<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.andersonmesq.autosavi.controller.MainController"
           stylesheets="@overlay.css">

    <VBox spacing="10" maxWidth="320" styleClass="overlay-container">

        <!-- HEADER -->
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="header">

            <Label text="AutoSavi" styleClass="title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="⚙" styleClass="icon-button"/>
            <Button text="✖" onAction="#onClose" styleClass="icon-button"/>

        </HBox>

        <VBox fx:id="container" spacing="10"/>

    </VBox>

</StackPane>