<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.andersonmesq.autosavi.controller.ConfigController"
            prefHeight="400.0" prefWidth="600.0">
    <VBox spacing="10" alignment="CENTER">
        <ComboBox fx:id="comboPrestador" prefWidth="300"/>
        <HBox spacing="10">
            <Button text="Iniciar" onAction="#onStart"/>
            <Button text="Pausar" onAction="#onPause"/>
            <Button text="Cancelar" onAction="#onCancel"/>
        </HBox>
        <Label fx:id="labelStatus" text="Status: IDLE"/>
        <TextArea fx:id="areaLogs" prefHeight="200"/>
    </VBox>
</AnchorPane>
