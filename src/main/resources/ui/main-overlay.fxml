<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.andersonmesq.autosavi.controller.MainController"
           stylesheets="@overlay.css">

    <VBox spacing="10" maxWidth="320" styleClass="overlay-container">

        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="header">
            <Button text="←" onAction="#onBack" styleClass="icon-button"/>
            <Button fx:id="btnHome" text="🏠" onAction="#onHome" styleClass="icon-button"/>
            <Button fx:id="btnPlanilha" text="𝄜" onAction="#onGerarPlanilhaModelo" styleClass="icon-button"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="✖" onAction="#onClose" styleClass="icon-button"/>

        </HBox>

        <VBox fx:id="container" spacing="10"/>

        <Label fx:id="lblStatus" text="..." />

    </VBox>

</StackPane>