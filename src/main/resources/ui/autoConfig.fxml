<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.andersonmesq.autosavi.controller.AutoConfigController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Seleção de prestador -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Prestador:" />
        <ComboBox fx:id="comboPrestadores" prefWidth="250"/>
        <Button text="Atualizar" onAction="#onAtualizarPrestadores"/>
    </HBox>

    <!-- Botões de controle -->
    <HBox spacing="10" alignment="CENTER">
        <Button text="Iniciar" onAction="#onIniciar"/>
        <Button text="Pausar" onAction="#onPausar"/>
        <Button text="Cancelar" onAction="#onCancelar"/>
    </HBox>

    <!-- Área de log -->
    <VBox spacing="5">
        <Label text="Logs:" />
        <TextArea fx:id=""
                  prefHeight="300"
                  wrapText="true"
                  editable="false"/>
    </VBox>

    <Label fx:id="lblStatus" text="Status..." />

</VBox>